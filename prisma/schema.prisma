generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model QaRun {
  id                Int        @id @default(autoincrement())
  filename          String
  createdAt         DateTime   @default(now())
  totalIds          Int
  bothPresent       Int
  missingInEn       Int
  missingInTh       Int
  conflictingEnText Int
  conflictingThText Int
  results           QaResult[]
}

model QaResult {
  id               Int    @id @default(autoincrement())
  runId            Int
  cmsId            String
  overrideId       String?
  sectionName      String?
  sourceObjectPath String?
  enText           String?
  thText           String?
  status           String

  run QaRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([cmsId])
}